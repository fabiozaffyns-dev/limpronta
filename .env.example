# ─────────────────────────────────────────────────────────────────────────────
# L'Impronta — variabili d'ambiente (copia in .env e compila)
# ─────────────────────────────────────────────────────────────────────────────

# Database PostgreSQL (Neon). Usa la stringa "pooled" per l'app.
# Per le migrazioni su Neon è consigliata la stringa DIRETTA (non-pooled):
# imposta temporaneamente DATABASE_URI alla direct string oppure usa DATABASE_URI_DIRECT.
DATABASE_URI=postgres://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/limpronta?sslmode=require
DATABASE_URI_DIRECT=postgres://USER:PASSWORD@HOST.REGION.aws.neon.tech/limpronta?sslmode=require

# Segreto Payload (genera una stringa casuale lunga, es. `openssl rand -hex 32`)
PAYLOAD_SECRET=CAMBIA_QUESTO_SECRET

# URL pubblico del sito (serve a Payload per email, preview, sitemap)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Cloudinary (storage immagini). Se vuote, in sviluppo si usa lo storage su disco.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp Business in formato E.164 senza "+" (es. 393331234567).
# PLACEHOLDER: il fisso 011 6206975 NON è un numero WhatsApp.
NEXT_PUBLIC_WHATSAPP_NUMBER=393330000000

# Formspree (form di backup). Endpoint del form, es. https://formspree.io/f/xxxxxx
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
